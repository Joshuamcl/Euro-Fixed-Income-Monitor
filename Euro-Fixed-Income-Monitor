        "## 2. Data Cleaning and Preparation"
      ],
      "metadata": {
        "id": "q0y4EAXy8Bl8"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "def prepare_series(df, value_name):\n",
        "    df = df.copy()\n",
        "    df = df.reset_index()\n",
        "\n",
        "    df = df.iloc[:, [1, -1]]\n",
        "    df.columns = [\"date\", value_name]\n",
        "\n",
        "    df[\"date\"] = pd.to_datetime(df[\"date\"], format=\"%d %b %Y\", errors=\"coerce\")\n",
        "    df[value_name] = pd.to_numeric(df[value_name], errors=\"coerce\")\n",
        "\n",
        "    df = df.dropna(subset=[\"date\"])\n",
        "    df = df.sort_values(\"date\").reset_index(drop=True)\n",
        "\n",
        "    return df"
      ],
      "metadata": {
        "id": "1VD2748ubwfu"
      },
      "execution_count": 151,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "estr_clean = prepare_series(estr, \"estr\")\n",
        "dfr_clean = prepare_series(dfr, \"dfr\")\n",
        "y2_clean = prepare_series(y2, \"y2\")\n",
        "y5_clean = prepare_series(y5, \"y5\")\n",
        "y10_clean = prepare_series(y10, \"y10\")\n",
        "y30_clean = prepare_series(y30, \"y30\")"
      ],
      "metadata": {
        "id": "G0tebhrWd8ZR"
      },
      "execution_count": 152,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "market_data = estr_clean.merge(dfr_clean, on=\"date\", how=\"outer\")\n",
