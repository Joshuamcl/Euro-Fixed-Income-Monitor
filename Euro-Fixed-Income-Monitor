        "    face_value=bond_face_value,\n",
        "    coupon_rate=bond_coupon_rate,\n",
        "    yield_rate=market_yield,\n",
        "    maturity_years=remaining_years\n",
        ")\n",
        "\n",
        "mod_dur = modified_duration(\n",
        "    face_value=bond_face_value,\n",
        "    coupon_rate=bond_coupon_rate,\n",
        "    yield_rate=market_yield,\n",
        "    maturity_years=remaining_years\n",
        ")\n",
        "\n",
        "approx_price_change_pct = -mod_dur * 0.001 * 100\n",
        "\n",
        "print(\"Duration analysis\")\n",
        "print(\"-----------------\")\n",
        "print(f\"Macaulay duration: {mac_dur:.2f} years\")\n",
