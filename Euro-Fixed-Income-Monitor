        "## 8. Bond Sensitivity Analysis\n",
        "For this part, I chose a real German Bund because it is widely followed in euro fixed income markets, and i had already studied German sovereign bonds in class, which made me the example more intuitive to work with."
      ],
      "metadata": {
        "id": "chr-63Ic8-J3"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "bond_coupon_rate = 0.029\n",
        "bond_face_value = 100\n",
        "bond_maturity_date = pd.Timestamp(\"2036-02-15\")\n",
        "valuation_date = analysis_data.iloc[-1][\"date\"]\n",
        "market_yield = analysis_data.iloc[-1][\"y10\"] / 100\n",
        "\n",
        "years_to_maturity = (bond_maturity_date - valuation_date).days /365.25\n",
        "remaining_years = int(round(years_to_maturity))\n",
        "\n",
        "print(\"Bond inputs\")\n",
        "print(\"-----------\")\n",
        "print(f\"Valuation date: {valuation_date.date()}\")\n",
        "print(f\"Bund maturity: {bond_maturity_date.date()}\")\n",
        "print(f\"Coupon rate: {bond_coupon_rate*100:.2f}%\")\n",
        "print(f\"Approx. market yield: {market_yield*100:.3f}%\")\n",
        "print(f\"Remaining years: {remaining_years}\")"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "C741jmbiy__3",
        "outputId": "a7cfb05b-d452-45b1-8e5d-664a65225276"
      },
      "execution_count": 164,
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "Bond inputs\n",
            "-----------\n",
            "Valuation date: 2026-04-22\n",
            "Bund maturity: 2036-02-15\n",
            "Coupon rate: 2.90%\n",
            "Approx. market yield: 3.051%\n",
            "Remaining years: 10\n"
          ]
        }
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "def bond_price(face_value, coupon_rate, yield_rate, maturity_years):\n",
        "  price = 0\n",
        "\n",
        "  for t in range(1, maturity_years + 1):\n",
        "    coupon = face_value * coupon_rate\n",
        "    price += coupon / ((1 + yield_rate) ** t)\n",
        "\n",
        "  price += face_value / ((1 + yield_rate) ** maturity_years)\n",
        "  return price"
      ],
      "metadata": {
        "id": "z9MmI72E0wVg"
      },
      "execution_count": 165,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "base_price = bond_price(\n",
        "    face_value=bond_face_value,\n",
        "    coupon_rate=bond_coupon_rate,\n",
        "    yield_rate=market_yield,\n",
        "    maturity_years=remaining_years\n",
        ")\n",
        "\n",
        "shocked_yield = market_yield + 0.001\n",
        "shocked_price = bond_price(\n",
        "    face_value=bond_face_value,\n",
        "    coupon_rate=bond_coupon_rate,\n",
        "    yield_rate=shocked_yield,\n",
        "    maturity_years=remaining_years\n",
        ")\n",
        "\n",
        "price_change = shocked_price - base_price\n",
        "price_change_pct = (price_change / base_price) * 100\n",
        "\n",
        "print(\"Bond sensitivity\")\n",
        "print(\"----------------\")\n",
        "print(f\"Base price: {base_price:.2f}\")\n",
        "print(f\"Price after +10 bps shock: {shocked_price:.2f}\")\n",
        "print(f\"Price change: {price_change:.2f}\")\n",
        "print(f\"Price change (%): {price_change_pct:.2f}%\")"
      ],
      "metadata": {
        "colab": {
