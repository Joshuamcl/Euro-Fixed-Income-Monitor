    {
      "cell_type": "code",
      "source": [
        "def macaulay_duration(face_value, coupon_rate, yield_rate, maturity_years):\n",
        "    price = bond_price(face_value, coupon_rate, yield_rate, maturity_years)\n",
        "    weighted_sum = 0\n",
        "\n",
        "    for t in range(1, maturity_years + 1):\n",
        "        coupon = face_value * coupon_rate\n",
        "        pv_coupon = coupon / ((1 + yield_rate) ** t)\n",
        "        weighted_sum += t * pv_coupon\n",
        "\n",
        "    pv_face_value = face_value / ((1 + yield_rate) ** maturity_years)\n",
        "    weighted_sum += maturity_years * pv_face_value\n",
        "\n",
        "    return weighted_sum / price\n",
        "\n",
        "def modified_duration(face_value, coupon_rate, yield_rate, maturity_years):\n",
        "    mac_dur = macaulay_duration(face_value, coupon_rate, yield_rate, maturity_years)\n",
        "    return mac_dur / (1 + yield_rate)"
      ],
      "metadata": {
        "id": "5jKNiJkC59C7"
      },
